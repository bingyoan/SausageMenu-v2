# Server-only secrets. Configure these in Zeabur; never expose them as NEXT_PUBLIC values.
GEMINI_API_KEY=replace_with_server_gemini_key
GEMINI_PAID_DAILY_LIMIT=50
AUTH_SESSION_SECRET=replace_with_at_least_32_random_characters
SUBSCRIPTION_USER_ID_SECRET=replace_with_a_different_random_secret
REVENUECAT_SECRET_API_KEY=replace_with_revenuecat_secret_key

# Public RevenueCat SDK keys. These are embedded in the mobile bundle at build time.
NEXT_PUBLIC_REVENUECAT_APPLE_KEY=appl_xxx
NEXT_PUBLIC_REVENUECAT_GOOGLE_KEY=goog_xxx

# Existing database configuration.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key
